# Discord Developer Gateway Configuration

# The bot application token from the Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# The application ID (Client ID) of your bot
CLIENT_ID=your_application_client_id_here

# (Highly Recommended) The ID of your development guild/server for instant slash command registration.
# If left blank, commands will register globally (takes up to 1 hour to propagate).
GUILD_ID=your_discord_guild_id_here

# Root directory for scanning projects
PROJECTS_ROOT=~/Projects

# (Optional) Token quota tracking settings
MONTHLY_QUOTA_LIMIT=5000000
QUOTA_RESET_DAY=1

# Gateway location identifier (e.g. HELSINKI or NUREMBERG)
GATEWAY_NAME=HELSINKI
